@model IEnumerable<SistemaSaludGoya.Models.Estudio>

<div class="container mt-4">
    <h2>Listado de Estudios Médicos</h2>
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Estudio</th>
                <th>Paciente</th>
                <th>Fecha</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Consulta.Turno.Paciente.Usuario.Apellido, @item.Consulta.Turno.Paciente.Usuario.Nombre</td>
                    <td>@item.Consulta.FechaConsulta.ToString("dd/MM/yyyy")</td>
                    <td><a asp-action="Details" asp-route-id="@item.IdEstudio" class="btn btn-sm btn-info">Ver</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>