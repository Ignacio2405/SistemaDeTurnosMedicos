@{
    ViewData["Title"] = "Solicitar Turno";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .page-header { margin-bottom: 2rem; }
    .page-tag { display:inline-block; background:#E5ECF0; color:#2A6F97; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; padding:0.3rem 0.8rem; border-radius:20px; margin-bottom:0.5rem; }
    .page-title { font-size:1.7rem; font-weight:800; color:#1a3a4f; letter-spacing:-0.5px; }
    .page-subtitle { font-size:0.9rem; color:#64748b; margin-top:0.2rem; }

    .turno-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
    @@media(max-width:680px){ .turno-form-grid{grid-template-columns:1fr;} }

    .form-field { display:flex; flex-direction:column; gap:0.4rem; }
    .form-label { font-size:0.82rem; font-weight:600; color:#374151; text-transform:uppercase; letter-spacing:0.4px; }
    .form-select, .form-input {
        padding:0.65rem 0.9rem; border:1.5px solid #e2e8f0; border-radius:10px;
        font-size:0.9rem; color:#1a3a4f; background:white; outline:none;
        transition:border 0.18s, box-shadow 0.18s;
    }
    .form-select:focus, .form-input:focus { border-color:#2A6F97; box-shadow:0 0 0 3px rgba(42,111,151,0.1); }
    .form-select:disabled { background:#f8fafc; color:#94a3b8; cursor:not-allowed; }

    .horarios-grid { display:grid; grid-template-columns:1fr; gap:0.75rem; margin-top:0.25rem; }
    
    .slot-btn {
        padding:0.8rem 1rem; border:1.5px solid #e2e8f0; border-radius:10px; background:white;
        font-size:0.95rem; font-weight:600; color:#374151; cursor:pointer; text-align:left;
        transition:all 0.15s; display:flex; justify-content:space-between; align-items:center;
    }
    .slot-btn:hover:not(:disabled) { border-color:#2A6F97; background:#eef5fa; color:#2A6F97; }
    .slot-btn.selected { background:#2A6F97; color:white; border-color:#2A6F97; }
    
    /* Agotado / No disponible */
    .slot-btn.ocupado {
        background:#f8fafc; color:#94a3b8; border-color:#e2e8f0;
        cursor:not-allowed; opacity:0.8;
    }
    .slot-btn:disabled { cursor:not-allowed; }

    .horarios-loading { color:#64748b; font-size:0.85rem; padding:1rem 0; }

    .btn-submit { background:#2A6F97; color:white; border:none; padding:0.75rem 2rem; border-radius:12px; font-weight:700; font-size:0.95rem; cursor:pointer; transition:all 0.18s; box-shadow:0 4px 14px rgba(42,111,151,0.25); display:inline-flex; align-items:center; gap:0.5rem; }
    .btn-submit:hover { background:#1a4f6e; transform:translateY(-1px); }
    .btn-submit:disabled { opacity:0.5; cursor:not-allowed; transform:none; }
    .btn-volver { color:#64748b; font-size:0.875rem; text-decoration:none; display:inline-flex; align-items:center; gap:0.3rem; }
    .btn-volver:hover { color:#2A6F97; text-decoration:none; }

    .validation-error { background:#fff5f5; border:1px solid #fca5a5; border-radius:10px; padding:0.75rem 1rem; color:#c62828; font-size:0.875rem; margin-bottom:1rem; }
</style>

<div class="page-header">
    <span class="page-tag">📅 Nuevo Turno</span>
    <h1 class="page-title">Solicitar turno médico</h1>
    <p class="page-subtitle">Elegí especialidad, profesional y bloque horario disponible</p>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="validation-error">
        @Html.ValidationSummary(true)
    </div>
}

<div class="app-card">
    <div class="app-card-header">
        <span>🩺</span>
        <h4>Datos del turno</h4>
    </div>
    <div class="app-card-body">
        <form method="post" asp-action="Create" id="formTurno">
            <div class="turno-form-grid" style="margin-bottom:1.25rem;">
                <div class="form-field">
                    <label class="form-label" for="sel-especialidad">Especialidad</label>
                    <select id="sel-especialidad" class="form-select" required>
                        <option value="">— Seleccioná una especialidad —</option>
                        @foreach (var esp in (List<SistemaSaludGoya.Models.Especialidad>)ViewBag.Especialidades)
                        {
                            <option value="@esp.IdEspecialidad">@esp.Nombre</option>
                        }
                    </select>
                </div>

                <div class="form-field">
                    <label class="form-label" for="sel-medico">Profesional</label>
                    <select id="sel-medico" name="MedicoId" class="form-select" required disabled>
                        <option value="">— Primero elegí especialidad —</option>
                    </select>
                </div>

                <div class="form-field">
                    <label class="form-label" for="inp-fecha">Fecha</label>
                    <input type="text" id="inp-fecha" name="Fecha" class="form-input"
                           placeholder="Seleccioná médico primero..." required disabled readonly />
                    <p id="dias-habiles-hint" style="font-size:0.75rem;color:#64748b;margin-top:0.25rem;display:none;"></p>
                </div>

                <div class="form-field">
                    <label class="form-label" for="inp-motivo">Motivo de consulta</label>
                    <input type="text" id="inp-motivo" name="Motivo" class="form-input"
                           placeholder="Ej: Control anual, dolor de cabeza..." maxlength="200" />
                </div>
            </div>

            <div class="form-field" style="margin-bottom:1.5rem;">
                <label class="form-label">Bloque horario</label>
                <div id="horarios-container">
                    <p class="horarios-loading">Seleccioná un médico y fecha para ver disponibilidad.</p>
                </div>
                <input type="hidden" name="Hora" id="inp-hora" required />
            </div>

            <div style="display:flex; align-items:center; gap:1.5rem; flex-wrap:wrap;">
                <button type="submit" class="btn-submit" id="btn-submit" disabled>📅 Confirmar turno</button>
                <a asp-controller="Turno" asp-action="Index" class="btn-volver" id="link-volver">← Volver a mis turnos</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/airbnb.css" />
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
<style>
    .flatpickr-calendar { font-family:'Inter',sans-serif; border-radius:14px; box-shadow:0 8px 30px rgba(0,0,0,0.15); }
    .flatpickr-day.selected, .flatpickr-day.selected:hover { background:#2A6F97; border-color:#2A6F97; }
    .flatpickr-day.flatpickr-disabled { color:#d1d5db; text-decoration:line-through; opacity:0.5; cursor:not-allowed; }
</style>
<script>
    const selEsp       = document.getElementById('sel-especialidad');
    const selMedico    = document.getElementById('sel-medico');
    const inpFecha     = document.getElementById('inp-fecha');
    const diasHint     = document.getElementById('dias-habiles-hint');
    const horariosCont = document.getElementById('horarios-container');
    const inpHora      = document.getElementById('inp-hora');
    const btnSubmit    = document.getElementById('btn-submit');

    let fpInstance = null;

    function initFlatpickr() {
        if (fpInstance) fpInstance.destroy();
        fpInstance = flatpickr(inpFecha, {
            locale: 'es',
            dateFormat: 'Y-m-d',
            minDate: 'today',
            maxDate: new Date(new Date().setMonth(new Date().getMonth() + 3)),
            onChange: async function(selectedDates, dateStr) {
                inpFecha.value = dateStr;
                if (dateStr && selMedico.value) {
                    await cargarHorarios(selMedico.value, dateStr);
                } else {
                    limpiarHorarios();
                }
            }
        });
        inpFecha.disabled = false;
        inpFecha.placeholder = 'Elegí cualquier fecha...';
    }

    selEsp.addEventListener('change', async function () {
        const id = this.value;
        selMedico.innerHTML = '<option value="">Cargando...</option>';
        selMedico.disabled = true;
        inpFecha.disabled  = true;
        inpFecha.value     = '';
        diasHint.style.display = 'none';
        limpiarHorarios();
        if (fpInstance) { fpInstance.destroy(); fpInstance = null; }

        if (!id) {
            selMedico.innerHTML = '<option value="">— Primero elegí especialidad —</option>';
            return;
        }

        const resp   = await fetch(`/Turno/ObtenerMedicosPorEspecialidad?idEspecialidad=${id}`);
        const medicos = await resp.json();
        selMedico.innerHTML = '<option value="">— Seleccioná un profesional —</option>';
        medicos.forEach(m => {
            const opt = document.createElement('option');
            opt.value = m.idMedico;
            opt.textContent = `Dr/a. ${m.nombre}`;
            selMedico.appendChild(opt);
        });
        selMedico.disabled = medicos.length === 0;
        if (medicos.length === 0) selMedico.innerHTML = '<option value="">Sin profesionales disponibles</option>';
    });

    selMedico.addEventListener('change', function () {
        inpFecha.value = '';
        limpiarHorarios();
        diasHint.style.display = 'none';
        if (fpInstance) { fpInstance.destroy(); fpInstance = null; }

        if (!this.value) { inpFecha.disabled = true; return; }
        
        diasHint.innerHTML = `💡 Seleccioná el día para ver si hay capacidad o excepciones.`;
        diasHint.style.cssText = 'display:block;font-size:0.75rem;color:#2e7d32;margin-top:0.25rem;';
        initFlatpickr();
    });

    async function cargarHorarios(medicoId, fecha) {
        horariosCont.innerHTML = '<p class="horarios-loading">⏳ Comprobando capacidad y excepciones...</p>';
        inpHora.value = '';
        actualizarSubmit();

        const resp = await fetch(`/Turno/ObtenerHorariosOcupados?medicoId=${medicoId}&fecha=${fecha}`);
        const data = await resp.json();

        if (!data.disponible && (!data.slots || data.slots.length === 0)) {
            horariosCont.innerHTML = `<p class="horarios-loading">😕 ${data.mensaje || 'No hay horarios disponibles para este día.'}</p>`;
            return;
        }

        const grid = document.createElement('div');
        grid.className = 'horarios-grid';

        data.slots.forEach(slot => {
            const btn = document.createElement('button');
            btn.type = 'button';
            
            const horaSpan = document.createElement('span');
            horaSpan.textContent = slot.texto;
            btn.appendChild(horaSpan);

            if (slot.ocupado) {
                btn.className = 'slot-btn ocupado';
                btn.disabled = true;
                
                const estadoSpan = document.createElement('span');
                estadoSpan.textContent = '❌ Sin cupo';
                estadoSpan.style.fontSize = '0.75rem';
                btn.appendChild(estadoSpan);
            } else {
                btn.className = 'slot-btn';
                btn.dataset.hora = slot.hora;
                
                const estadoSpan = document.createElement('span');
                estadoSpan.textContent = '✅ Disponible';
                estadoSpan.style.fontSize = '0.75rem';
                estadoSpan.style.color = '#2e7d32';
                btn.appendChild(estadoSpan);

                btn.addEventListener('click', function () {
                    document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
                    this.classList.add('selected');
                    inpHora.value = this.dataset.hora.length === 5 ? this.dataset.hora + ':00' : this.dataset.hora;
                    actualizarSubmit();
                });
            }
            grid.appendChild(btn);
        });
        horariosCont.innerHTML = '';
        horariosCont.appendChild(grid);
    }

    function limpiarHorarios() {
        horariosCont.innerHTML = '<p class="horarios-loading">Seleccioná un médico y fecha para ver disponibilidad.</p>';
        inpHora.value = '';
        actualizarSubmit();
    }

    function actualizarSubmit() {
        btnSubmit.disabled = !selMedico.value || !inpFecha.value || !inpHora.value;
    }
</script>
}