@model IEnumerable<SistemaSaludGoya.Models.Paciente>

@{
    ViewData["Title"] = "Listado de Pacientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Listado de Pacientes</h2>
        <a asp-action="Create" class="btn btn-success">Registrar Nuevo Paciente</a>
    </div>

    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>DNI</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Teléfono</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var paciente in Model)
                {
                    <tr>
                        <td>@paciente.Dni</td>
                        <td>@paciente.Usuario.Nombre</td>
                        <td>@paciente.Usuario.Apellido</td>
                        <td>@(paciente.Telefono ?? "No asignado")</td>
                        <td>
                            @if (paciente.Suspendido)
                            {
                                <span class="badge bg-danger">Suspendido</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@paciente.IdPaciente" class="btn btn-info btn-sm text-white">Ver Historial / Detalles</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No hay pacientes registrados en el sistema actualmente.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
