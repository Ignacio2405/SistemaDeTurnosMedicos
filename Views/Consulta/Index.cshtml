@model IEnumerable<SistemaSaludGoya.Models.Consulta>

@{
    ViewData["Title"] = "Historial de Consultas Médicas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Historial de Consultas Clínicas</h2>
    </div>

    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>ID Consulta</th>
                <th>Fecha Turno</th>
                <th>Paciente</th>
                <th>Médico Atendió</th>
                <th>Diagnóstico / Motivo</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var consulta in Model) 
                {
                    <tr>
                        <td>@consulta.IdConsulta</td>

                        <td>@consulta.FechaConsulta.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>@consulta.Turno.Paciente.Usuario.Apellido, @consulta.Turno.Paciente.Usuario.Nombre</td>
                        <td>Dr/a. @consulta.Turno.Medico.Usuario.Apellido, @consulta.Turno.Medico.Usuario.Nombre</td>

                        <td>
                            @{
                                var textoDiagnostico = consulta.Diagnostico ?? "Sin especificar";
                                if (textoDiagnostico.Length > 50) { textoDiagnostico = textoDiagnostico.Substring(0, 47) + "..."; }
                            }
                            @textoDiagnostico
                        </td>

                        <td>
                            <a asp-action="Details" asp-route-id="@consulta.IdConsulta" class="btn btn-info btn-sm text-white">Ver Ficha Médica</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No se registran consultas médicas procesadas aún.</td>
                </tr>
            }
        </tbody>
    </table>
</div>