@model SistemaSaludGoya.ViewModel.EditarPerfilVM
@{
    ViewData["Title"] = "Mi Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool esMedico = Model.Rol == "medico";
    bool esPaciente = Model.Rol == "paciente";
}
<style>
    .perfil-header { margin-bottom:1.5rem; }
    .page-tag { display:inline-block; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; padding:0.3rem 0.8rem; border-radius:20px; margin-bottom:0.5rem; }
    .tag-paciente { background:#e3f2fd; color:#1565c0; }
    .tag-medico { background:#ede7f6; color:#6a1b9a; }
    .tag-recepcionista { background:#e8f5e9; color:#2e7d32; }
    .tag-administrador { background:#fce4ec; color:#c62828; }
    .page-title { font-size:1.7rem; font-weight:800; color:#1a3a4f; }

    .section-card { background:white; border-radius:16px; box-shadow:0 4px 20px rgba(0,0,0,0.06); margin-bottom:1.5rem; overflow:hidden; }
    .section-head { padding:1rem 1.25rem; border-bottom:1px solid #f0f4f7; display:flex; align-items:center; gap:0.5rem; }
    .section-head h4 { font-size:0.95rem; font-weight:700; color:#1a3a4f; margin:0; }
    .section-body { padding:1.25rem; }

    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    @@media(max-width:600px){ .form-grid{grid-template-columns:1fr;} }
    .form-group { margin-bottom:1rem; }
    .form-label { font-size:0.8rem; font-weight:600; color:#374151; text-transform:uppercase; letter-spacing:0.4px; display:block; margin-bottom:0.4rem; }
    .form-control { width:100%; padding:0.6rem 0.85rem; border:1.5px solid #e2e8f0; border-radius:10px; font-size:0.9rem; outline:none; transition:border 0.18s; }
    .form-control:focus { border-color:#2A6F97; box-shadow:0 0 0 3px rgba(42,111,151,0.1); }
    .pass-hint { font-size:0.75rem; color:#94a3b8; margin-top:0.25rem; }
    .required-mark { color:#c62828; }
    .btn-guardar { background:linear-gradient(135deg,#2A6F97,#1a4f6e); color:white; border:none; padding:0.7rem 1.75rem; border-radius:12px; font-weight:700; font-size:0.9rem; cursor:pointer; transition:all 0.18s; }
    .btn-guardar:hover { opacity:0.9; transform:translateY(-1px); }

    /* Estilos para campos bloqueados */
    .input-group { display: flex; gap: 0.5rem; align-items: center; }
    .btn-edit-field { background: #f1f5f9; border: 1.5px solid #e2e8f0; padding: 0.6rem 1rem; border-radius: 10px; font-weight: 600; color: #475569; cursor: pointer; transition: all 0.2s; white-space: nowrap; font-size: 0.85rem; }
    .btn-edit-field:hover { background: #e2e8f0; color: #1e293b; }
    .form-control[readonly] { background: #f8fafc; color: #64748b; cursor: not-allowed; border-color: #f1f5f9; }

    /* Horarios */
    .dia-row { display:grid; grid-template-columns:110px 1fr 1fr 1fr; align-items:center; gap:1rem; padding:0.75rem 0; border-bottom:1px solid #f0f4f7; }
    .dia-row:last-child { border-bottom:none; }
    @@media(max-width:580px){ .dia-row{grid-template-columns:1fr; gap:0.4rem;} }
    .dia-check-label { display:flex; align-items:center; gap:0.5rem; font-weight:600; font-size:0.9rem; cursor:pointer; }
    .dia-check { width:18px; height:18px; accent-color:#6a1b9a; cursor:pointer; }
    .hora-group { display:flex; flex-direction:column; gap:0.2rem; }
    .hora-label { font-size:0.7rem; font-weight:600; color:#94a3b8; text-transform:uppercase; }
    .hora-input { padding:0.45rem 0.7rem; border:1.5px solid #e2e8f0; border-radius:8px; font-size:0.875rem; outline:none; width:100%; }
    .hora-input:focus { border-color:#6a1b9a; }
    .turno-selector { display:flex; gap:0.5rem; flex-wrap:wrap; }
    .btn-turno { padding:0.35rem 0.75rem; border:1.5px solid #e2e8f0; border-radius:8px; font-size:0.78rem; font-weight:600; cursor:pointer; background:white; transition:all 0.15s; }
    .btn-turno:hover { border-color:#6a1b9a; color:#6a1b9a; }
    .turno-hint { font-size:0.78rem; color:#94a3b8; margin-bottom:0.75rem; }
    .dias-desactivados input[type=time], .dias-desactivados input[type=text] { opacity:0.3; pointer-events:none; }
</style>

@if (TempData["AlertInfo"] != null)
{
    <div style="background:linear-gradient(135deg,#1565c0,#0d47a1);color:white;border-radius:14px;padding:1.1rem 1.4rem;margin-bottom:1.5rem;display:flex;align-items:center;gap:0.75rem;box-shadow:0 4px 20px rgba(21,101,192,0.3);">
        <span style="font-size:1.4rem;">📋</span>
        <div>
            <strong style="display:block;font-size:0.95rem;">Acción requerida</strong>
            <span style="font-size:0.875rem;opacity:0.9;">@TempData["AlertInfo"]</span>
        </div>
    </div>
}
@if (TempData["Success"] != null)
{ <div class="alert-app-success">✅ @TempData["Success"]</div> }

<div class="perfil-header">
    @{
        var tagClass = Model.Rol.ToLower() switch {
            "medico" => "tag-medico", "paciente" => "tag-paciente",
            "recepcionista" => "tag-recepcionista", _ => "tag-administrador" };
    }
    <span class="page-tag @tagClass">👤 @Model.Rol</span>
    <h1 class="page-title">Mi perfil</h1>
</div>

<div class="section-card">
    <div class="section-head"><span>📋</span><h4>Datos personales</h4></div>
    <div class="section-body">
        <form method="post" asp-action="GuardarPerfil" autocomplete="off">
            
            <div asp-validation-summary="All" class="text-danger" style="color:#c62828; font-weight:bold; margin-bottom:1rem; font-size:0.85rem;"></div>

            <input type="hidden" asp-for="IdUsuario" />
            <input type="hidden" asp-for="Rol" />

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Nombre <span class="required-mark">*</span></label>
                    <input asp-for="Nombre" class="form-control" id="perfil-nombre" />
                    <span asp-validation-for="Nombre" style="color:#c62828;font-size:0.8rem;"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Apellido <span class="required-mark">*</span></label>
                    <input asp-for="Apellido" class="form-control" id="perfil-apellido" />
                    <span asp-validation-for="Apellido" style="color:#c62828;font-size:0.8rem;"></span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Email <span class="required-mark">*</span></label>
                <div class="input-group">
                    <input asp-for="Email" type="email" class="form-control" id="perfil-email" readonly autocomplete="off" />
                    <button type="button" class="btn-edit-field" onclick="habilitarEdicion('perfil-email', this)">✏️ Cambiar</button>
                </div>
                <span asp-validation-for="Email" style="color:#c62828;font-size:0.8rem;"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Nueva contraseña</label>
                <div class="input-group">
                    <input asp-for="NuevaPassword" type="password" class="form-control" placeholder="Bloqueado por seguridad" id="perfil-password" readonly autocomplete="new-password" />
                    <button type="button" class="btn-edit-field" onclick="habilitarEdicion('perfil-password', this)">✏️ Cambiar</button>
                </div>
                <p class="pass-hint">Hacé clic en "Cambiar" si querés actualizar tu contraseña.</p>
                <span asp-validation-for="NuevaPassword" style="color:#c62828;font-size:0.8rem;"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Teléfono</label>
                <input asp-for="Telefono" class="form-control" placeholder="+54 9 ..." id="perfil-telefono" />
            </div>

            @if (esPaciente)
            {
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">DNI</label>
                        <input asp-for="Dni" class="form-control" placeholder="Tu DNI" id="perfil-dni" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha de nacimiento</label>
                        <input asp-for="FechaNacimiento" type="date" class="form-control" id="perfil-nacimiento" value="@(Model.FechaNacimiento?.ToString("yyyy-MM-dd"))" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Dirección</label>
                    <input asp-for="Direccion" class="form-control" placeholder="Tu dirección" id="perfil-direccion" />
                </div>
            }

            @if (esMedico)
            {
                <div class="form-group">
                    <label class="form-label">Matrícula</label>
                    <input asp-for="Matricula" class="form-control" placeholder="MP-12345" id="perfil-matricula" />
                </div>
            }

            <button type="submit" class="btn-guardar" id="btn-guardar-datos" style="margin-top: 0.5rem;">💾 Guardar datos personales</button>
        </form>
    </div>
</div>

@if (esMedico)
{
    <div class="section-card">
        <div class="section-head"><span>🗓️</span><h4>Horarios de atención semanal</h4></div>
        <div class="section-body">
            <p class="turno-hint">Seleccioná los días que trabajás y el rango horario. Podés usar los atajos de turno para auto-completar.</p>

            <div style="margin-bottom:1rem;">
                <span style="font-size:0.8rem;font-weight:600;color:#374151;margin-right:0.5rem;">Atajo:</span>
                <div class="turno-selector" style="display:inline-flex;">
                    <button type="button" class="btn-turno" onclick="setTurno('manana')" id="btn-turno-manana">🌅 Mañana (8–13)</button>
                    <button type="button" class="btn-turno" onclick="setTurno('tarde')" id="btn-turno-tarde">🌇 Tarde (13–20)</button>
                    <button type="button" class="btn-turno" onclick="setTurno('ambos')" id="btn-turno-ambos">🌞 Ambos (8–20)</button>
                </div>
            </div>

            <form method="post" asp-action="GuardarHorarios" id="formHorarios">
                <div id="dias-container">
                    @for (int i = 0; i < Model.Horarios.Count; i++)
                    {
                        var h = Model.Horarios[i];
                        <div class="dia-row" id="dia-row-@i">
                            <label class="dia-check-label">
                                <input type="checkbox"
                                       class="dia-check"
                                       id="dia-activo-@i"
                                       data-idx="@i"
                                       @(h.Activo ? "checked" : "")
                                       onchange="toggleDia(@i, this.checked)" />
                                @h.NombreDia
                            </label>
                            <div class="hora-group">
                                <span class="hora-label">Desde</span>
                                <input type="time" value="@h.HoraDesde"
                                       class="hora-input" id="hora-desde-@i"
                                       @(h.Activo ? "" : "disabled") />
                            </div>
                            <div class="hora-group">
                                <span class="hora-label">Hasta</span>
                                <input type="time" value="@h.HoraHasta"
                                       class="hora-input" id="hora-hasta-@i"
                                       @(h.Activo ? "" : "disabled") />
                            </div>
                            <div class="dia-status" style="font-size:0.75rem;color:#94a3b8;">
                                @(h.Activo ? "✅ Activo" : "—")
                            </div>
                        </div>
                    }
                </div>
                <button type="submit" class="btn-guardar" id="btn-guardar-horarios" style="margin-top:1rem;">🗓️ Guardar horarios</button>
            </form>
        </div>
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    //función para desbloquear los inputs de Email y Password
    function habilitarEdicion(inputId, btnElement) {
        const input = document.getElementById(inputId);
        input.removeAttribute('readonly');
        input.focus();
        if (inputId === 'perfil-password') {
            input.placeholder = "Escribí tu nueva contraseña";
        }
        btnElement.style.display = 'none';
    }

    function toggleDia(i, checked) {
        document.getElementById('hora-desde-' + i).disabled = !checked;
        document.getElementById('hora-hasta-' + i).disabled = !checked;
        const row = document.getElementById('dia-row-' + i);
        row.querySelector('.dia-status').textContent = checked ? '✅ Activo' : '—';
    }

    function setTurno(tipo) {
        const configs = {
            manana: { desde: '08:00', hasta: '13:00' },
            tarde:  { desde: '13:00', hasta: '20:00' },
            ambos:  { desde: '08:00', hasta: '20:00' }
        };
        const c = configs[tipo];
        document.querySelectorAll('.dia-check:checked').forEach(cb => {
            const i = cb.dataset.idx;
            document.getElementById('hora-desde-' + i).value = c.desde;
            document.getElementById('hora-hasta-' + i).value = c.hasta;
        });
    }

    document.getElementById('formHorarios')?.addEventListener('submit', function(e) {
        e.preventDefault();
        const form = this;
        form.querySelectorAll('.dia-check, .hora-input').forEach(el => el.removeAttribute('name'));

        const totalDias = 7;
        for (let i = 0; i < totalDias; i++) {
            const cb = document.getElementById('dia-activo-' + i);
            const desde = document.getElementById('hora-desde-' + i);
            const hasta = document.getElementById('hora-hasta-' + i);

            const addHidden = (name, value) => {
                const h = document.createElement('input');
                h.type = 'hidden'; h.name = name; h.value = value;
                form.appendChild(h);
            };

            addHidden('diasActivos', cb?.checked ? 'true' : 'false');
            addHidden('horasDesde', desde?.value || '08:00');
            addHidden('horasHasta', hasta?.value || '13:00');
        }
        form.submit();
    });
</script>
}